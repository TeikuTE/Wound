      "section": "ENTRY_003 — Operational Procedures",
      "desc": "Let It Rot",
      "passage": "4. Let It Rot. Your oldest Active Scar fades.",
      "passage_short": "4. Let It Rot. Your oldest Active Scar",
      "glyphs": [
