    {
      "section": "ENTRY_004 — Faction Pressure",
      "desc": "opening",
      "passage": "The factions think they can use you. Other way around. You use THEM.",
      "passage_short": "The factions think they can use you. Other",
      "glyphs": [],
      "footnotes": [
        {
          "n": 43,
          "text": "The bells. They are in the vents now. Not in the prose. Chen — if you can hear me — tell me how to SYNC. I am losing the frequency.",
          "act": 4,
          "late": false
        }
      ]
    },
    {
      "section": "ENTRY_004 — Faction Pressure",
      "desc": "the four factions described",
      "passage": "The Church of the Holy Second: pain-loving pious...",
      "passage_short": "The Church of the Holy Second: pain-loving pious...",
      "glyphs": [],
      "footnotes": [
        {
          "n": 44,
          "text": "The Church wants me to take the ritual. The Authority wants me to take the loop. Scionfall wants me to take the dignity-of-stillness. Rose wants me to take the needle. None of them want me to put the book down.",
          "act": 4,
          "late": false
        }
      ]
    },
    {
      "section": "ENTRY_005 — Fracture Events",
      "desc": "opening",
      "passage": "Chen thinks of these guys as panic attacks because she still believes you can survive them through technique. I call them what they are.",
      "passage_short": "Chen thinks of these guys as panic attacks",
