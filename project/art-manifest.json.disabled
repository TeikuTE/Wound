    {
      "section": "Appendix H — Saul Files",
      "desc": "the framing line",
      "passage": "The pages that follow were not part of the original manuscript. They arrived after. A man who was not the man whose name...",
      "passage_short": "The pages that follow were not part of",
      "glyphs": [],
      "footnotes": [
        {
          "n": 53,
          "text": "His name was Saul. I named my Echo Saul. I did not know. I am not sure anymore that I named him at all.",
          "act": 5,
          "late": false
        }
      ]
    },
    {
      "section": "Appendix H — Saul Files",
      "desc": "deeper in the Saul Files",
      "passage": "(further into the recovered testimony — the specific lines depend on what you draft for Saul's actual files)",
      "passage_short": "(further into the recovered testimony — the specific",
      "glyphs": [],
      "footnotes": [
