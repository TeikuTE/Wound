  "placements": [
    {
      "section": "Foreword — \"A Note Before You Begin\"",
      "desc": "opening of the foreword",
      "passage": "You're reading something that came to me at the lowest point in my life.",
      "passage_short": "You're reading something that came to me at",
      "glyphs": [],
      "footnotes": []
    },
    {
      "section": "Foreword — \"A Note Before You Begin\"",
      "desc": "the NICU passage",
      "passage": "During the first seven months after my wife had given birth, we were in a constant struggle for survival.",
      "passage_short": "During the first seven months after my wife",
      "glyphs": [],
      "footnotes": [
        {
          "n": 2,
          "text": "He's writing about the NICU and I'm reading it in the same chair I sat in three months ago waiting for my own kid's blood work. Bad time to start this book. Doing it anyway.",
          "act": 1,
          "late": false
        }
      ]
    },
    {
      "section": "Foreword — \"A Note Before You Begin\"",
      "desc": "the tefillin moment",
      "passage": "I lost my tefillin. If you know you know.",
      "passage_short": "I lost my tefillin. If you know you",
      "glyphs": [],
      "footnotes": [
        {
          "n": 3,
          "text": "Oh. He's frum. He's frum and he lost his tefillin in the wellness room. I have read three lines past that sentence five times. Going to make tea.",
          "act": 1,
          "late": false
        }
      ]
    },
    {
      "section": "Foreword — \"A Note Before You Begin\"",
      "desc": "the closing warning",
      "passage": "If you're reading this, it means you found this copy. If you're holding it in your hands — be careful what you write in the margins. The book remembers.",
      "passage_short": "If you're reading this, it means you found",
      "glyphs": [
        {
          "glyph": "null",
          "size": 6,
          "stage": 0,
          "late": false
        }
      ],
      "footnotes": [
        {
          "n": 4,
          "text": "Most metal opening sentence in a TTRPG manual since Cy_Borg. We are cooking.",
          "act": 1,
          "late": false
        },
        {
          "n": 57,
          "text": "I was already an Echo when I picked it up.",
          "act": 5,
          "late": true
        }
      ]
    },
    {
      "section": "How to Use This Book",
      "desc": "the warning against cover-to-cover",
      "passage": "Temporal Echoes is designed for progressive complexity. Do not read it cover to cover. You will be overwhelmed and you will quit. Read in stages.",
      "passage_short": "Temporal Echoes is designed for progressive complexity. Do",
      "glyphs": [],
      "footnotes": [
        {
          "n": 5,
          "text": "A bit pretentious. Going to play along. Starting with Anachron and seeing if I can keep an Echo intact.",
          "act": 1,
          "late": false
        }
      ]
    },
    {
      "section": "How to Use This Book",
      "desc": "the Document Structure list",
      "passage": "Book 1: Temporal Echoes (Chapters 1-8) ... Appendices: Appendix A: The Harmonic Codex ...",
      "passage_short": "Book 1: Temporal Echoes (Chapters 1-8) ... Appendices:",
      "glyphs": [],
      "footnotes": [
        {
          "n": 6,
          "text": "Eight appendices for a \"first 3 sessions\" game. The author needs a Reduction phase. Structure is solid though.",
          "act": 1,
          "late": false
        }
      ]
    },
    {
